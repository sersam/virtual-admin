{
  "name": "administrador-virtual-inteligente",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @admin/web",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run test:root && node scripts/run-workspace-script.mjs test",
    "test:root": "node --test scripts/*.test.mjs",
    "test:coverage": "npm run test:root && node scripts/run-workspace-script.mjs test:coverage",
    "test:e2e": "node scripts/run-workspace-script.mjs test:e2e",
    "build": "npm run build:root && node scripts/run-workspace-script.mjs build",
    "build:root": "tsc -p tsconfig.json",
    "changes:validate": "node scripts/validate-changes.mjs",
    "changes:consume": "node scripts/consume-changes.mjs",
    "quality": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run build && npm run test:e2e && npm run changes:validate"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^16.2.0",
    "jsdom": "26.1.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.0"
  },
  "engines": {
    "node": ">=20"
  }
}
